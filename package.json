{
  "name": "tnd-granite-landing",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "build": "next build --webpack",
    "build:clean": "npm run clean && npm run build",
    "deploy:check": "npm run build:clean",
    "start": "next start"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "~5.9.3"
  }
}
