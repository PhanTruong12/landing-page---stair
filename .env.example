# Copy sang .env.local khi dev; trên Vercel: Project → Settings → Environment Variables (Production + Preview).
# Gốc site công khai (không dấu / cuối) — metadata, OG, JSON-LD
NEXT_PUBLIC_SITE_ORIGIN=https://tndgranite-vn.vercel.app

NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# URL Web App (Deploy → Anyone). Không bọc dấu nháy — nếu có '...' URL sẽ sai
NEXT_PUBLIC_SHEETS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
# Cùng một Web App cho 2 site: trang cầu thang = stairs (tab LandingPage); site form cũ = website (tab Website)
NEXT_PUBLIC_SHEETS_LEAD_TARGET=stairs
